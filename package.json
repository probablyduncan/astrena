{
  "name": "@probablyduncan/astrena",
  "version": "1.0.1",
  "description": "are.na channel content loader for astro.build",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/probablyduncan/astrena"
  },
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "keywords": [
    "astro-loader",
    "withastro",
    "astro-component",
    "are.na",
    "arena"
  ],
  "license": "MIT",
  "peerDependencies": {
    "astro": ">=5.0.0"
  },
  "dependencies": {
    "@aredotna/sdk": "^0.0.4"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "astro": "^5.0.0",
    "semantic-release": "^25.0.5",
    "tsdown": "^0.22.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "scripts": {
    "build": "tsc --noEmit && tsdown src/index.ts --dts --clean",
    "dev": "tsdown src/index.ts --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  }
